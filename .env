# Пример конфигурации базы данных
# Скопируйте этот файл в .env и измените значения под вашу среду

# Выбор движка базы данных:
# sqlite3, mysql, postgresql, oracle
DB_ENGINE=sqlite3

# Общие параметры для всех БД кроме SQLite

DB_NAME=db.sqlite3

#DB_NAME=msudle
#DB_USER=postgres
#DB_PASSWORD=postgres
#DB_HOST=localhost
#DB_PORT=5432

